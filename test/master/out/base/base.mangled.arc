        while ((b & 1) == 0) { b = b / 2; }
        if (a > b) { i32 t = a; a = b; b = t; }
        b = b - a;
    }
    i32 r = a;
    for (i32 i = 0; i < shift; i++) { r = r * 2; }
    return r;
}

i32 t2_3_152_sub(i32 a, i32 b) {
    while (a != b) {
        if (a > b) { a = a - b; } else { b = b - a; }
    }
