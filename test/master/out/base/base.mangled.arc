i32 t5_4_35_xorrev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n / 2; i++) {
        a[i] = a[i] ^ a[n-1-i];
        a[n-1-i] = a[i] ^ a[n-1-i];
        a[i] = a[i] ^ a[n-1-i];
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

