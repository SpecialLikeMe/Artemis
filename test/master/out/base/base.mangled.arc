    if (v3 < m) { m = v3; }
    if (v2 < m) { m = v2; }
    if (v1 < m) { m = v1; }
    if (v0 < m) { m = v0; }
    return m;
}

i32 t3_4_33_ternary(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
