}

i32 t7_1_107_scan(i32 n) {
    i32 c = 0;
    for (i32 i = 1; i <= n; i++) { if (i % 2 != 0) { c++; } }
    return c;
}

i32 t7_1_107_fml(i32 n) { return (n + 1) / 2; }

i32 t7_1_107_bit(i32 n) {
    i32 c = 0;
    for (i32 i = 1; i <= n; i++) { c = c + (i & 1); }
    return c;
}

i32 t7_1_107_bwd(i32 n) {
    i32 c = 0;
    for (i32 i = n; i >= 1; i--) { if ((i & 1) != 0) { c++; } }
    return c;
}

i32 t7_1_107_arr(i32 n) {
    i32[50] a; i32 k = 0;
    for (i32 i = 1; i <= n; i++) { if (i % 2 != 0) { a[k] = i; k = k + 1; } }
    return k;
}

i32 ck_1_107() {
