i32 t2_2_122_iter(i32 a, i32 b) {
    while (b != 0) { i32 t = b; b = a % b; a = t; }
    return a;
}

i32 t2_2_122_rec(i32 a, i32 b) {
    if (b == 0) { return a; }
    return t2_2_122_rec(b, a % b);
