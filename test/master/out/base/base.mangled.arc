i32 t5_4_35_rev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    i32 lo = 0; i32 hi = n - 1;
    while (lo < hi) {
        i32 t = a[lo]; a[lo] = a[hi]; a[hi] = t;
        lo++; hi--;
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 t5_4_35_copyrev_sum(i32 n) {
    i32[50] a; i32[50] b;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n; i++) { b[i] = a[n - 1 - i]; }
