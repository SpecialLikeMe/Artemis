i32 t6_4_16_rec(i32 n) {
    if (n <= 1) { return n; }
    return t6_4_16_rec(n - 1) + t6_4_16_rec(n - 2);
}

i32 t6_4_16_iter(i32 n) {
    if (n <= 1) { return n; }
