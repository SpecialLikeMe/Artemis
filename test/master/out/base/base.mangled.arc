    while (((a | b) & 1) == 0) { a = a / 2; b = b / 2; shift++; }
    while ((a & 1) == 0) { a = a / 2; }
    while (b != 0) {
        while ((b & 1) == 0) { b = b / 2; }
        if (a > b) { i32 t = a; a = b; b = t; }
        b = b - a;
    }
    i32 r = a;
