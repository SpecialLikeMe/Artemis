i32 t2_9_2_rec(i32 a, i32 b) {
    if (b == 0) { return a; }
    return t2_9_2_rec(b, a % b);
}

i32 t2_9_2_bin(i32 a, i32 b) {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    i32 shift = 0;
    while (((a | b) & 1) == 0) { a = a / 2; b = b / 2; shift++; }
    while ((a & 1) == 0) { a = a / 2; }
    while (b != 0) {
        while ((b & 1) == 0) { b = b / 2; }
        if (a > b) { i32 t = a; a = b; b = t; }
        b = b - a;
    }
