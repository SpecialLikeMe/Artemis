    if (t2_2_2_sub(a, b)  != E) { return 33; }
    if (t2_2_2_iter(a, b) != t2_2_2_rec(a, b))  { return 34; }
    if (t2_2_2_iter(a, b) != t2_2_2_bin(a, b))  { return 35; }
    return 0;
}

