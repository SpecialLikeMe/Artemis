    i32 d = t0_8_0_twoptr(S); if (d != E) { return 13; }
    i32 e = t0_8_0_tr(S);     if (e != E) { return 14; }
    i32 g = t0_8_0_arr(S);    if (g != E) { return 15; }
    i32 h = t0_8_0_str2(S);   if (h != E) { return 16; }
    return 0;
}

