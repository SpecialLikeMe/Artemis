    }
    return 0;
}

i32 t3_2_113_fwd(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m = v0;
    if (v1 < m) { m = v1; }
    if (v2 < m) { m = v2; }
    if (v3 < m) { m = v3; }
    if (v4 < m) { m = v4; }
    if (v5 < m) { m = v5; }
    return m;
}

i32 t3_2_113_bwd(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m = v5;
    if (v4 < m) { m = v4; }
    if (v3 < m) { m = v3; }
    if (v2 < m) { m = v2; }
    if (v1 < m) { m = v1; }
    if (v0 < m) { m = v0; }
    return m;
}

i32 t3_2_113_ternary(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m01 = v0 < v1 ? v0 : v1;
    i32 m23 = v2 < v3 ? v2 : v3;
    i32 m45 = v4 < v5 ? v4 : v5;
    i32 m03 = m01 < m23 ? m01 : m23;
    return m03 < m45 ? m03 : m45;
}

struct T3S_2_113 { i32 v; }
i32 t3_2_113_struct(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
