        if (t4_10_194_kern(n) != t4_10_194_lut(n))  { return n + 100; }
    }
    return 0;
}

i32 t5_10_195_rev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    i32 lo = 0; i32 hi = n - 1;
    while (lo < hi) {
        i32 t = a[lo]; a[lo] = a[hi]; a[hi] = t;
        lo++; hi--;
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 t5_10_195_copyrev_sum(i32 n) {
    i32[50] a; i32[50] b;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n; i++) { b[i] = a[n - 1 - i]; }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + b[i]; }
    return s;
}

i32 t5_10_195_xorrev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n / 2; i++) {
        a[i] = a[i] ^ a[n-1-i];
        a[n-1-i] = a[i] ^ a[n-1-i];
        a[i] = a[i] ^ a[n-1-i];
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 ck_10_195() {
    i32 S = 31; i32 E = 496;
    if (t5_10_195_rev_sum(S)     != E) { return 60; }
    if (t5_10_195_copyrev_sum(S) != E) { return 61; }
    if (t5_10_195_xorrev_sum(S)  != E) { return 62; }
    return 0;
}

i32 st_10_195() {
    for (i32 n = 1; n <= 31; n++) {
        i32 r = t5_10_195_rev_sum(n);
        if (t5_10_195_copyrev_sum(n) != r) { return n; }
        if (t5_10_195_xorrev_sum(n)  != r) { return n + 100; }
    }
    return 0;
}

i32 t6_10_196_rec(i32 n) {
    if (n <= 1) { return n; }
    return t6_10_196_rec(n - 1) + t6_10_196_rec(n - 2);
}

i32 t6_10_196_iter(i32 n) {
    if (n <= 1) { return n; }
    i32 a = 0; i32 b = 1;
    for (i32 i = 2; i <= n; i++) { i32 c = a + b; a = b; b = c; }
    return b;
}

i32 t6_10_196_memo(i32 n) {
    i32[15] m;
    m[0] = 0; m[1] = 1;
    for (i32 i = 2; i <= n; i++) { m[i] = m[i-1] + m[i-2]; }
    return m[n];
}

i32 t6_10_196_trh(i32 n, i32 a, i32 b) {
    if (n == 0) { return a; }
    return t6_10_196_trh(n - 1, b, a + b);
}
i32 t6_10_196_tr(i32 n) { return t6_10_196_trh(n, 0, 1); }

i32 ck_10_196() {
    i32 N = 3; i32 E = 2;
    if (t6_10_196_rec(N)  != E) { return 70; }
    if (t6_10_196_iter(N) != E) { return 71; }
    if (t6_10_196_memo(N) != E) { return 72; }
    if (t6_10_196_tr(N)   != E) { return 73; }
    return 0;
}

i32 st_10_196() {
    for (i32 n = 2; n <= 3; n++) {
        i32 r = t6_10_196_iter(n);
        if (t6_10_196_rec(n)  != r) { return n; }
        if (t6_10_196_memo(n) != r) { return n + 100; }
        if (t6_10_196_tr(n)   != r) { return n + 200; }
    }
    return 0;
}

i32 t7_10_197_scan(i32 n) {
    i32 c = 0;
    for (i32 i = 1; i <= n; i++) { if (i % 2 != 0) { c++; } }
    return c;
}

i32 t7_10_197_fml(i32 n) { return (n + 1) / 2; }

i32 t7_10_197_bit(i32 n) {
    i32 c = 0;
    for (i32 i = 1; i <= n; i++) { c = c + (i & 1); }
    return c;
}

i32 t7_10_197_bwd(i32 n) {
    i32 c = 0;
    for (i32 i = n; i >= 1; i--) { if ((i & 1) != 0) { c++; } }
    return c;
}

i32 t7_10_197_arr(i32 n) {
    i32[50] a; i32 k = 0;
    for (i32 i = 1; i <= n; i++) { if (i % 2 != 0) { a[k] = i; k = k + 1; } }
    return k;
}

i32 ck_10_197() {
    i32 S = 31; i32 E = 16;
    if (t7_10_197_scan(S) != E) { return 80; }
    if (t7_10_197_fml(S)  != E) { return 81; }
    if (t7_10_197_bit(S)  != E) { return 82; }
    if (t7_10_197_bwd(S)  != E) { return 83; }
    if (t7_10_197_arr(S)  != E) { return 84; }
    return 0;
}

i32 st_10_197() {
    for (i32 n = 1; n <= 31; n++) {
        i32 r = t7_10_197_fml(n);
        if (t7_10_197_scan(n) != r) { return n; }
        if (t7_10_197_bit(n)  != r) { return n + 100; }
    }
    return 0;
}

i32 t8_10_198_shallow(i32 x) {
    if (0) { x = x + 1000; }
    if (0) { x = x * 2; }
    if (1) { i32 unused = x + 1; }
    if (0) { return -1; }
    return x;
}

i32 t8_10_198_nested(i32 x) {
    if (0) {
        if (1) { x = x + 999; }
        x = x - 1;
    }
    i32 y = x;
    if (0) { y = y + 500; }
    if (1) {
        if (0) { y = -y; }
    }
    return y;
}

i32 t8_10_198_const_fold(i32 x) {
    i32 flag = 5 - 5;
    if (flag != 0) { x = x + 777; }
    i32 cond = 3 * 4 - 12;
    if (cond > 0)  { x = x + 888; }
    return x;
}

i32 t8_10_198_ssa(i32 x) {
    i32 r = x + 1000;
    r = x;
    i32 q = r + 500;
    q = r;
    return q;
}

i32 t8_10_198_deadloop(i32 x) {
    while (0) { x = x * 999; }
    for (i32 i = 0; i < 0; i++) { x = x - 1; }
    return x;
}

i32 ck_10_198() {
