i32 t0_7_0_fwd(i32 n) {
    i32 s = 0;
    for (i32 i = 1; i <= n; i++) { s = s + i; }
    return s;
}

i32 t0_7_0_bwd(i32 n) {
    i32 s = 0; i32 i = n;
    while (i > 0) { s = s + i; i = i - 1; }
    return s;
}

i32 t0_7_0_fml(i32 n) { return (n * (n + 1)) / 2; }

i32 t0_7_0_twoptr(i32 n) {
    i32 lo = 1; i32 hi = n; i32 s = 0;
    while (lo < hi) { s = s + lo + hi; lo++; hi--; }
    if (lo == hi) { s = s + lo; }
    return s;
}

i32 t0_7_0_trh(i32 i, i32 s, i32 n) {
    if (i > n) { return s; }
    return t0_7_0_trh(i + 1, s + i, n);
}
i32 t0_7_0_tr(i32 n) { return t0_7_0_trh(1, 0, n); }

i32 t0_7_0_arr(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 t0_7_0_str2(i32 n) {
    i32 s = 0;
    for (i32 i = 1; i <= n; i = i + 2) { s = s + i; }
    for (i32 i = 2; i <= n; i = i + 2) { s = s + i; }
    return s;
}

i32 ck_7_0() {
    i32 S = 40; i32 E = 820;
    i32 a = t0_7_0_fwd(S);    if (a != E) { return 10; }
    i32 b = t0_7_0_bwd(S);    if (b != E) { return 11; }
    i32 c = t0_7_0_fml(S);    if (c != E) { return 12; }
    i32 d = t0_7_0_twoptr(S); if (d != E) { return 13; }
    i32 e = t0_7_0_tr(S);     if (e != E) { return 14; }
    i32 g = t0_7_0_arr(S);    if (g != E) { return 15; }
    i32 h = t0_7_0_str2(S);   if (h != E) { return 16; }
    return 0;
}

i32 st_7_0() {
    for (i32 n = 1; n <= 40; n++) {
        i32 r = t0_7_0_fml(n);
        if (t0_7_0_fwd(n)    != r) { return n; }
        if (t0_7_0_bwd(n)    != r) { return n + 100; }
        if (t0_7_0_twoptr(n) != r) { return n + 200; }
        if (t0_7_0_arr(n)    != r) { return n + 300; }
    }
    return 0;
}

i32 t1_7_1_whl(i32 n) {
    i32 r = 0; i32 i = 0;
    while (i < n) { r++; i++; }
    return r;
}

i32 t1_7_1_for(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i < n; i++) { r = r + 1; }
    return r;
}

i32 t1_7_1_rec(i32 n) {
    if (n <= 0) { return 0; }
    return 1 + t1_7_1_rec(n - 1);
}

i32 t1_7_1_ptr(i32 n) {
    i32 x = n;
    i32* p2 = &x;
    i32 r = 0;
    while (*p2 > 0) { r++; *p2 = *p2 - 1; }
    return r;
}

i32 t1_7_1_sub(i32 n) {
    i32 r = n;
    i32 z = 0;
    while (r > z) { z++; }
    return z;
}

i32 t1_7_1_strided(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i + 1 < n; i = i + 2) { r = r + 2; }
    if (n % 2 != 0) { r = r + 1; }
    return r;
}

i32 ck_7_1() {
    i32 S = 40;
    if (t1_7_1_whl(S)     != S) { return 20; }
    if (t1_7_1_for(S)     != S) { return 21; }
    if (t1_7_1_rec(S)     != S) { return 22; }
    if (t1_7_1_ptr(S)     != S) { return 23; }
    if (t1_7_1_sub(S)     != S) { return 24; }
    if (t1_7_1_strided(S) != S) { return 25; }
    return 0;
}

i32 st_7_1() {
    for (i32 n = 1; n <= 40; n++) {
        if (t1_7_1_whl(n) != n) { return n; }
        if (t1_7_1_for(n) != n) { return n + 100; }
        if (t1_7_1_rec(n) != n) { return n + 200; }
    }
    return 0;
}

i32 t2_7_2_iter(i32 a, i32 b) {
    while (b != 0) { i32 t = b; b = a % b; a = t; }
    return a;
}

i32 t2_7_2_rec(i32 a, i32 b) {
    if (b == 0) { return a; }
    return t2_7_2_rec(b, a % b);
}

i32 t2_7_2_bin(i32 a, i32 b) {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    i32 shift = 0;
    while (((a | b) & 1) == 0) { a = a / 2; b = b / 2; shift++; }
    while ((a & 1) == 0) { a = a / 2; }
    while (b != 0) {
        while ((b & 1) == 0) { b = b / 2; }
        if (a > b) { i32 t = a; a = b; b = t; }
        b = b - a;
    }
    i32 r = a;
    for (i32 i = 0; i < shift; i++) { r = r * 2; }
    return r;
}

i32 t2_7_2_sub(i32 a, i32 b) {
    while (a != b) {
        if (a > b) { a = a - b; } else { b = b - a; }
    }
    return a;
}

i32 ck_7_2() {
    i32 a = 80; i32 b = 120; i32 E = 40;
    if (t2_7_2_iter(a, b) != E) { return 30; }
    if (t2_7_2_rec(a, b)  != E) { return 31; }
    if (t2_7_2_bin(a, b)  != E) { return 32; }
    if (t2_7_2_sub(a, b)  != E) { return 33; }
    if (t2_7_2_iter(a, b) != t2_7_2_rec(a, b))  { return 34; }
    if (t2_7_2_iter(a, b) != t2_7_2_bin(a, b))  { return 35; }
    return 0;
}

i32 st_7_2() {
    for (i32 n = 1; n <= 40; n++) {
        i32 g1 = t2_7_2_iter(n * 2, n * 3);
        i32 g2 = t2_7_2_rec(n * 2, n * 3);
        if (g1 != n) { return n; }
        if (g2 != n) { return n + 100; }
    }
    return 0;
}

i32 t3_7_3_fwd(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m = v0;
    if (v1 < m) { m = v1; }
    if (v2 < m) { m = v2; }
    if (v3 < m) { m = v3; }
    if (v4 < m) { m = v4; }
    if (v5 < m) { m = v5; }
    return m;
}

i32 t3_7_3_bwd(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m = v5;
    if (v4 < m) { m = v4; }
    if (v3 < m) { m = v3; }
    if (v2 < m) { m = v2; }
    if (v1 < m) { m = v1; }
    if (v0 < m) { m = v0; }
    return m;
}

i32 t3_7_3_ternary(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m01 = v0 < v1 ? v0 : v1;
    i32 m23 = v2 < v3 ? v2 : v3;
    i32 m45 = v4 < v5 ? v4 : v5;
    i32 m03 = m01 < m23 ? m01 : m23;
    return m03 < m45 ? m03 : m45;
}

