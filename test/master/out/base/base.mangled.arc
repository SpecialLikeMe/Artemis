    while (i < n) { r++; i++; }
    return r;
}

i32 t1_1_101_for(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i < n; i++) { r = r + 1; }
    return r;
}

i32 t1_1_101_rec(i32 n) {
    if (n <= 0) { return 0; }
    return 1 + t1_1_101_rec(n - 1);
}

i32 t1_1_101_ptr(i32 n) {
    i32 x = n;
    i32* p2 = &x;
    i32 r = 0;
    while (*p2 > 0) { r++; *p2 = *p2 - 1; }
    return r;
}

i32 t1_1_101_sub(i32 n) {
    i32 r = n;
    i32 z = 0;
    while (r > z) { z++; }
    return z;
}

i32 t1_1_101_strided(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i + 1 < n; i = i + 2) { r = r + 2; }
    if (n % 2 != 0) { r = r + 1; }
    return r;
}

i32 ck_1_101() {
    i32 S = 12;
    if (t1_1_101_whl(S)     != S) { return 20; }
    if (t1_1_101_for(S)     != S) { return 21; }
    if (t1_1_101_rec(S)     != S) { return 22; }
    if (t1_1_101_ptr(S)     != S) { return 23; }
    if (t1_1_101_sub(S)     != S) { return 24; }
    if (t1_1_101_strided(S) != S) { return 25; }
    return 0;
}

i32 st_1_101() {
    for (i32 n = 1; n <= 12; n++) {
        if (t1_1_101_whl(n) != n) { return n; }
        if (t1_1_101_for(n) != n) { return n + 100; }
        if (t1_1_101_rec(n) != n) { return n + 200; }
    }
    return 0;
}

i32 t2_1_102_iter(i32 a, i32 b) {
    while (b != 0) { i32 t = b; b = a % b; a = t; }
    return a;
}

i32 t2_1_102_rec(i32 a, i32 b) {
    if (b == 0) { return a; }
    return t2_1_102_rec(b, a % b);
}

i32 t2_1_102_bin(i32 a, i32 b) {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    i32 shift = 0;
    while (((a | b) & 1) == 0) { a = a / 2; b = b / 2; shift++; }
    while ((a & 1) == 0) { a = a / 2; }
    while (b != 0) {
        while ((b & 1) == 0) { b = b / 2; }
        if (a > b) { i32 t = a; a = b; b = t; }
        b = b - a;
    }
    i32 r = a;
    for (i32 i = 0; i < shift; i++) { r = r * 2; }
    return r;
}

i32 t2_1_102_sub(i32 a, i32 b) {
    while (a != b) {
        if (a > b) { a = a - b; } else { b = b - a; }
    }
    return a;
}

i32 ck_1_102() {
    i32 a = 24; i32 b = 36; i32 E = 12;
    if (t2_1_102_iter(a, b) != E) { return 30; }
    if (t2_1_102_rec(a, b)  != E) { return 31; }
    if (t2_1_102_bin(a, b)  != E) { return 32; }
    if (t2_1_102_sub(a, b)  != E) { return 33; }
    if (t2_1_102_iter(a, b) != t2_1_102_rec(a, b))  { return 34; }
    if (t2_1_102_iter(a, b) != t2_1_102_bin(a, b))  { return 35; }
    return 0;
}

i32 st_1_102() {
    for (i32 n = 1; n <= 12; n++) {
        i32 g1 = t2_1_102_iter(n * 2, n * 3);
        i32 g2 = t2_1_102_rec(n * 2, n * 3);
        if (g1 != n) { return n; }
        if (g2 != n) { return n + 100; }
    }
    return 0;
}

i32 t3_1_103_fwd(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m = v0;
    if (v1 < m) { m = v1; }
    if (v2 < m) { m = v2; }
    if (v3 < m) { m = v3; }
    if (v4 < m) { m = v4; }
    if (v5 < m) { m = v5; }
    return m;
}

i32 t3_1_103_bwd(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m = v5;
    if (v4 < m) { m = v4; }
    if (v3 < m) { m = v3; }
    if (v2 < m) { m = v2; }
    if (v1 < m) { m = v1; }
    if (v0 < m) { m = v0; }
    return m;
}

i32 t3_1_103_ternary(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    i32 m01 = v0 < v1 ? v0 : v1;
    i32 m23 = v2 < v3 ? v2 : v3;
    i32 m45 = v4 < v5 ? v4 : v5;
    i32 m03 = m01 < m23 ? m01 : m23;
    return m03 < m45 ? m03 : m45;
}

struct T3S_1_103 { i32 v; }
i32 t3_1_103_struct(i32 v0, i32 v1, i32 v2, i32 v3, i32 v4, i32 v5) {
    T3S_1_103 best; best.v = v0;
    if (v1 < best.v) { best.v = v1; }
    if (v2 < best.v) { best.v = v2; }
    if (v3 < best.v) { best.v = v3; }
    if (v4 < best.v) { best.v = v4; }
    if (v5 < best.v) { best.v = v5; }
    return best.v;
}

i32 ck_1_103() {
    i32 E = 12;
    if (t3_1_103_fwd(17,15,13,12,14,16)    != E) { return 40; }
    if (t3_1_103_bwd(17,15,13,12,14,16)    != E) { return 41; }
    if (t3_1_103_ternary(17,15,13,12,14,16) != E) { return 42; }
    if (t3_1_103_struct(17,15,13,12,14,16)  != E) { return 43; }
    return 0;
}

i32 st_1_103() {
    i32 r1 = t3_1_103_fwd(17,15,13,12,14,16);
    i32 r2 = t3_1_103_bwd(17,15,13,12,14,16);
    i32 r3 = t3_1_103_ternary(17,15,13,12,14,16);
    if (r1 != r2 || r2 != r3) { return 1; }
    return 0;
}

i32 t4_1_104_loop(i32 x) {
    i32 c = 0;
    while (x != 0) { c = c + (x & 1); x = x / 2; }
    return c;
}

i32 t4_1_104_kern(i32 x) {
    i32 c = 0;
    while (x != 0) { x = x & (x - 1); c++; }
    return c;
}

i32 t4_1_104_lut(i32 x) {
    i32[16] t;
    t[0]=0; t[1]=1; t[2]=1; t[3]=2;
    t[4]=1; t[5]=2; t[6]=2; t[7]=3;
    t[8]=1; t[9]=2; t[10]=2; t[11]=3;
    t[12]=2; t[13]=3; t[14]=3; t[15]=4;
    i32 c = 0;
    while (x != 0) { c = c + t[x & 15]; x = x / 16; }
    return c;
}

i32 t4_1_104_par(i32 x) {
    x = x - ((x / 2) & 0x55555555);
    x = (x & 0x33333333) + ((x / 4) & 0x33333333);
    x = (x + (x / 16)) & 0x0F0F0F0F;
    return x % 255;
}

i32 ck_1_104() {
    i32 S = 12; i32 E = 2;
    if (t4_1_104_loop(S) != E) { return 50; }
    if (t4_1_104_kern(S) != E) { return 51; }
    if (t4_1_104_lut(S)  != E) { return 52; }
    if (t4_1_104_par(S)  != E) { return 53; }
    if (t4_1_104_loop(S) != t4_1_104_kern(S)) { return 54; }
    return 0;
}

i32 st_1_104() {
    for (i32 n = 1; n <= 12; n++) {
        if (t4_1_104_loop(n) != t4_1_104_kern(n)) { return n; }
        if (t4_1_104_kern(n) != t4_1_104_lut(n))  { return n + 100; }
    }
    return 0;
}

i32 t5_1_105_rev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    i32 lo = 0; i32 hi = n - 1;
    while (lo < hi) {
        i32 t = a[lo]; a[lo] = a[hi]; a[hi] = t;
        lo++; hi--;
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 t5_1_105_copyrev_sum(i32 n) {
    i32[50] a; i32[50] b;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n; i++) { b[i] = a[n - 1 - i]; }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + b[i]; }
    return s;
}

i32 t5_1_105_xorrev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n / 2; i++) {
        a[i] = a[i] ^ a[n-1-i];
        a[n-1-i] = a[i] ^ a[n-1-i];
        a[i] = a[i] ^ a[n-1-i];
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 ck_1_105() {
    i32 S = 12; i32 E = 78;
    if (t5_1_105_rev_sum(S)     != E) { return 60; }
    if (t5_1_105_copyrev_sum(S) != E) { return 61; }
    if (t5_1_105_xorrev_sum(S)  != E) { return 62; }
    return 0;
}

i32 st_1_105() {
    for (i32 n = 1; n <= 12; n++) {
        i32 r = t5_1_105_rev_sum(n);
        if (t5_1_105_copyrev_sum(n) != r) { return n; }
        if (t5_1_105_xorrev_sum(n)  != r) { return n + 100; }
    }
    return 0;
}

i32 t6_1_106_rec(i32 n) {
    if (n <= 1) { return n; }
    return t6_1_106_rec(n - 1) + t6_1_106_rec(n - 2);
}

i32 t6_1_106_iter(i32 n) {
    if (n <= 1) { return n; }
    i32 a = 0; i32 b = 1;
    for (i32 i = 2; i <= n; i++) { i32 c = a + b; a = b; b = c; }
    return b;
}

i32 t6_1_106_memo(i32 n) {
    i32[15] m;
    m[0] = 0; m[1] = 1;
    for (i32 i = 2; i <= n; i++) { m[i] = m[i-1] + m[i-2]; }
    return m[n];
}

i32 t6_1_106_trh(i32 n, i32 a, i32 b) {
    if (n == 0) { return a; }
    return t6_1_106_trh(n - 1, b, a + b);
}
i32 t6_1_106_tr(i32 n) { return t6_1_106_trh(n, 0, 1); }

i32 ck_1_106() {
    i32 N = 4; i32 E = 3;
    if (t6_1_106_rec(N)  != E) { return 70; }
    if (t6_1_106_iter(N) != E) { return 71; }
    if (t6_1_106_memo(N) != E) { return 72; }
    if (t6_1_106_tr(N)   != E) { return 73; }
    return 0;
}

i32 st_1_106() {
