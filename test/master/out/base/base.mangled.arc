    }
    return 0;
}

i32 t8_4_198_shallow(i32 x) {
    if (0) { x = x + 1000; }
    if (0) { x = x * 2; }
    if (1) { i32 unused = x + 1; }
    if (0) { return -1; }
    return x;
}

i32 t8_4_198_nested(i32 x) {
    if (0) {
        if (1) { x = x + 999; }
        x = x - 1;
    }
    i32 y = x;
    if (0) { y = y + 500; }
    if (1) {
        if (0) { y = -y; }
    }
    return y;
}

i32 t8_4_198_const_fold(i32 x) {
    i32 flag = 5 - 5;
    if (flag != 0) { x = x + 777; }
    i32 cond = 3 * 4 - 12;
    if (cond > 0)  { x = x + 888; }
    return x;
}

i32 t8_4_198_ssa(i32 x) {
    i32 r = x + 1000;
    r = x;
    i32 q = r + 500;
    q = r;
    return q;
}

i32 t8_4_198_deadloop(i32 x) {
    while (0) { x = x * 999; }
    for (i32 i = 0; i < 0; i++) { x = x - 1; }
    return x;
}

