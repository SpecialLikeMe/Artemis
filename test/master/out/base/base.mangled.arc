i32 t2_4_32_iter(i32 a, i32 b) {
    while (b != 0) { i32 t = b; b = a % b; a = t; }
    return a;
}

i32 t2_4_32_rec(i32 a, i32 b) {
    if (b == 0) { return a; }
    return t2_4_32_rec(b, a % b);
}

i32 t2_4_32_bin(i32 a, i32 b) {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    i32 shift = 0;
    while (((a | b) & 1) == 0) { a = a / 2; b = b / 2; shift++; }
    while ((a & 1) == 0) { a = a / 2; }
    while (b != 0) {
        while ((b & 1) == 0) { b = b / 2; }
        if (a > b) { i32 t = a; a = b; b = t; }
        b = b - a;
    }
    i32 r = a;
    for (i32 i = 0; i < shift; i++) { r = r * 2; }
    return r;
}

i32 t2_4_32_sub(i32 a, i32 b) {
    while (a != b) {
        if (a > b) { a = a - b; } else { b = b - a; }
    }
    return a;
}

