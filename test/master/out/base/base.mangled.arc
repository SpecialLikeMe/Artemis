i32 t4_4_44_loop(i32 x) {
    i32 c = 0;
    while (x != 0) { c = c + (x & 1); x = x / 2; }
    return c;
}

i32 t4_4_44_kern(i32 x) {
    i32 c = 0;
    while (x != 0) { x = x & (x - 1); c++; }
    return c;
}

i32 t4_4_44_lut(i32 x) {
    i32[16] t;
    t[0]=0; t[1]=1; t[2]=1; t[3]=2;
    t[4]=1; t[5]=2; t[6]=2; t[7]=3;
    t[8]=1; t[9]=2; t[10]=2; t[11]=3;
    t[12]=2; t[13]=3; t[14]=3; t[15]=4;
    i32 c = 0;
    while (x != 0) { c = c + t[x & 15]; x = x / 16; }
    return c;
}

i32 t4_4_44_par(i32 x) {
    x = x - ((x / 2) & 0x55555555);
    x = (x & 0x33333333) + ((x / 4) & 0x33333333);
    x = (x + (x / 16)) & 0x0F0F0F0F;
    return x % 255;
}

