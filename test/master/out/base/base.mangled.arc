}

i32 t6_2_116_rec(i32 n) {
    if (n <= 1) { return n; }
    return t6_2_116_rec(n - 1) + t6_2_116_rec(n - 2);
}

i32 t6_2_116_iter(i32 n) {
    if (n <= 1) { return n; }
    i32 a = 0; i32 b = 1;
    for (i32 i = 2; i <= n; i++) { i32 c = a + b; a = b; b = c; }
    return b;
}

i32 t6_2_116_memo(i32 n) {
    i32[15] m;
    m[0] = 0; m[1] = 1;
