i32 t4_3_104_par(i32 x) {
    x = x - ((x / 2) & 0x55555555);
    x = (x & 0x33333333) + ((x / 4) & 0x33333333);
    x = (x + (x / 16)) & 0x0F0F0F0F;
    return x % 255;
}

