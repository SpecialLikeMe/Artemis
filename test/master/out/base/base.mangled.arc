        if (t0_2_0_bwd(n)    != r) { return n + 100; }
        if (t0_2_0_twoptr(n) != r) { return n + 200; }
        if (t0_2_0_arr(n)    != r) { return n + 300; }
    }
    return 0;
}

i32 t1_2_1_whl(i32 n) {
    i32 r = 0; i32 i = 0;
    while (i < n) { r++; i++; }
    return r;
}

i32 t1_2_1_for(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i < n; i++) { r = r + 1; }
    return r;
}

i32 t1_2_1_rec(i32 n) {
    if (n <= 0) { return 0; }
    return 1 + t1_2_1_rec(n - 1);
}

i32 t1_2_1_ptr(i32 n) {
    i32 x = n;
    i32* p2 = &x;
    i32 r = 0;
    while (*p2 > 0) { r++; *p2 = *p2 - 1; }
    return r;
}

i32 t1_2_1_sub(i32 n) {
    i32 r = n;
    i32 z = 0;
    while (r > z) { z++; }
    return z;
}

i32 t1_2_1_strided(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i + 1 < n; i = i + 2) { r = r + 2; }
    if (n % 2 != 0) { r = r + 1; }
    return r;
}

i32 ck_2_1() {
    i32 S = 9;
    if (t1_2_1_whl(S)     != S) { return 20; }
    if (t1_2_1_for(S)     != S) { return 21; }
    if (t1_2_1_rec(S)     != S) { return 22; }
    if (t1_2_1_ptr(S)     != S) { return 23; }
    if (t1_2_1_sub(S)     != S) { return 24; }
    if (t1_2_1_strided(S) != S) { return 25; }
    return 0;
}

