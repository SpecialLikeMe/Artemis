    if (t2_2_112_sub(a, b)  != E) { return 33; }
    if (t2_2_112_iter(a, b) != t2_2_112_rec(a, b))  { return 34; }
    if (t2_2_112_iter(a, b) != t2_2_112_bin(a, b))  { return 35; }
    return 0;
}

