    return 0;
}

i32 t4_8_4_loop(i32 x) {
    i32 c = 0;
    while (x != 0) { c = c + (x & 1); x = x / 2; }
    return c;
}

i32 t4_8_4_kern(i32 x) {
    i32 c = 0;
    while (x != 0) { x = x & (x - 1); c++; }
    return c;
}

i32 t4_8_4_lut(i32 x) {
    i32[16] t;
    t[0]=0; t[1]=1; t[2]=1; t[3]=2;
    t[4]=1; t[5]=2; t[6]=2; t[7]=3;
    t[8]=1; t[9]=2; t[10]=2; t[11]=3;
    t[12]=2; t[13]=3; t[14]=3; t[15]=4;
    i32 c = 0;
    while (x != 0) { c = c + t[x & 15]; x = x / 16; }
    return c;
}

i32 t4_8_4_par(i32 x) {
    x = x - ((x / 2) & 0x55555555);
    x = (x & 0x33333333) + ((x / 4) & 0x33333333);
    x = (x + (x / 16)) & 0x0F0F0F0F;
    return x % 255;
}

i32 ck_8_4() {
    i32 S = 37; i32 E = 3;
    if (t4_8_4_loop(S) != E) { return 50; }
    if (t4_8_4_kern(S) != E) { return 51; }
    if (t4_8_4_lut(S)  != E) { return 52; }
    if (t4_8_4_par(S)  != E) { return 53; }
    if (t4_8_4_loop(S) != t4_8_4_kern(S)) { return 54; }
    return 0;
}

i32 st_8_4() {
    for (i32 n = 1; n <= 37; n++) {
        if (t4_8_4_loop(n) != t4_8_4_kern(n)) { return n; }
        if (t4_8_4_kern(n) != t4_8_4_lut(n))  { return n + 100; }
    }
    return 0;
}

i32 t5_8_5_rev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    i32 lo = 0; i32 hi = n - 1;
    while (lo < hi) {
        i32 t = a[lo]; a[lo] = a[hi]; a[hi] = t;
        lo++; hi--;
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 t5_8_5_copyrev_sum(i32 n) {
    i32[50] a; i32[50] b;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n; i++) { b[i] = a[n - 1 - i]; }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + b[i]; }
    return s;
}

i32 t5_8_5_xorrev_sum(i32 n) {
    i32[50] a;
    for (i32 i = 0; i < n; i++) { a[i] = i + 1; }
    for (i32 i = 0; i < n / 2; i++) {
        a[i] = a[i] ^ a[n-1-i];
        a[n-1-i] = a[i] ^ a[n-1-i];
        a[i] = a[i] ^ a[n-1-i];
    }
    i32 s = 0;
    for (i32 i = 0; i < n; i++) { s = s + a[i]; }
    return s;
}

i32 ck_8_5() {
