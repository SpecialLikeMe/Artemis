i32 t1_9_1_whl(i32 n) {
    i32 r = 0; i32 i = 0;
    while (i < n) { r++; i++; }
    return r;
}

i32 t1_9_1_for(i32 n) {
    i32 r = 0;
    for (i32 i = 0; i < n; i++) { r = r + 1; }
    return r;
}

i32 t1_9_1_rec(i32 n) {
    if (n <= 0) { return 0; }
    return 1 + t1_9_1_rec(n - 1);
}

i32 t1_9_1_ptr(i32 n) {
    i32 x = n;
    i32* p2 = &x;
    i32 r = 0;
    while (*p2 > 0) { r++; *p2 = *p2 - 1; }
    return r;
}

i32 t1_9_1_sub(i32 n) {
    i32 r = n;
    i32 z = 0;
    while (r > z) { z++; }
    return z;
}

i32 t1_9_1_strided(i32 n) {
