    if (t5_8_5_rev_sum(S)     != E) { return 60; }
    if (t5_8_5_copyrev_sum(S) != E) { return 61; }
    if (t5_8_5_xorrev_sum(S)  != E) { return 62; }
    return 0;
}

i32 st_8_5() {
    for (i32 n = 1; n <= 37; n++) {
        i32 r = t5_8_5_rev_sum(n);
        if (t5_8_5_copyrev_sum(n) != r) { return n; }
        if (t5_8_5_xorrev_sum(n)  != r) { return n + 100; }
    }
    return 0;
}

i32 t6_8_6_rec(i32 n) {
    if (n <= 1) { return n; }
    return t6_8_6_rec(n - 1) + t6_8_6_rec(n - 2);
}

i32 t6_8_6_iter(i32 n) {
    if (n <= 1) { return n; }
    i32 a = 0; i32 b = 1;
    for (i32 i = 2; i <= n; i++) { i32 c = a + b; a = b; b = c; }
    return b;
}

i32 t6_8_6_memo(i32 n) {
    i32[15] m;
    m[0] = 0; m[1] = 1;
    for (i32 i = 2; i <= n; i++) { m[i] = m[i-1] + m[i-2]; }
    return m[n];
}

i32 t6_8_6_trh(i32 n, i32 a, i32 b) {
    if (n == 0) { return a; }
    return t6_8_6_trh(n - 1, b, a + b);
}
i32 t6_8_6_tr(i32 n) { return t6_8_6_trh(n, 0, 1); }

i32 ck_8_6() {
