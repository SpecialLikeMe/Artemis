    if (t8_10_198_ssa(S)        != S) { return 93; }
    if (t8_10_198_deadloop(S)   != S) { return 94; }
    return 0;
}

i32 st_10_198() {
    for (i32 n = 1; n <= 31; n++) {
        if (t8_10_198_shallow(n)  != n) { return n; }
        if (t8_10_198_nested(n)   != n) { return n + 100; }
        if (t8_10_198_ssa(n)      != n) { return n + 200; }
    }
    return 0;
}

