i32 t0_1_110_fwd(i32 n) {
    i32 s = 0;
    for (i32 i = 1; i <= n; i++) { s = s + i; }
    return s;
}

i32 t0_1_110_bwd(i32 n) {
    i32 s = 0; i32 i = n;
    while (i > 0) { s = s + i; i = i - 1; }
    return s;
}

i32 t0_1_110_fml(i32 n) { return (n * (n + 1)) / 2; }

i32 t0_1_110_twoptr(i32 n) {
    i32 lo = 1; i32 hi = n; i32 s = 0;
    while (lo < hi) { s = s + lo + hi; lo++; hi--; }
    if (lo == hi) { s = s + lo; }
    return s;
}

i32 t0_1_110_trh(i32 i, i32 s, i32 n) {
    if (i > n) { return s; }
    return t0_1_110_trh(i + 1, s + i, n);
}
i32 t0_1_110_tr(i32 n) { return t0_1_110_trh(1, 0, n); }

i32 t0_1_110_arr(i32 n) {
