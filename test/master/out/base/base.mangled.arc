        if (t6_4_196_tr(n)   != r) { return n + 200; }
    }
    return 0;
}

i32 t7_4_197_scan(i32 n) {
    i32 c = 0;
    for (i32 i = 1; i <= n; i++) { if (i % 2 != 0) { c++; } }
    return c;
}

i32 t7_4_197_fml(i32 n) { return (n + 1) / 2; }

i32 t7_4_197_bit(i32 n) {
    i32 c = 0;
    for (i32 i = 1; i <= n; i++) { c = c + (i & 1); }
    return c;
}

i32 t7_4_197_bwd(i32 n) {
    i32 c = 0;
    for (i32 i = n; i >= 1; i--) { if ((i & 1) != 0) { c++; } }
    return c;
}

i32 t7_4_197_arr(i32 n) {
    i32[50] a; i32 k = 0;
    for (i32 i = 1; i <= n; i++) { if (i % 2 != 0) { a[k] = i; k = k + 1; } }
    return k;
}

i32 ck_4_197() {
